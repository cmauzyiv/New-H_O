import pygame
import constance as c
import random

class Engines(pygame.sprite.Sprite):
    def __init__(self):
        super(Engines, self).__init__()
        self.image = pygame.image.load("engine1.png")
        self.rect = self.image.get_rect()
        self.vel_x = 0
        self.vel_y = 0


    def update(self):
        self.rect.x += self.vel_x
        self.rect.y += self.vel_y